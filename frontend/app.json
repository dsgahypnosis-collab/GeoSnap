{
  "expo": {
    "name": "GeoSnap",
    "slug": "geosnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "geosnap",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Capture specimens for geological identification",
        "NSPhotoLibraryUsageDescription": "Select specimen photos from your gallery",
        "NSLocationWhenInUseUsageDescription": "Tag specimen locations for geological context"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0c0c0c"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0c0c0c"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GeoSnap to access your camera for specimen photography"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GeoSnap to access your location for geological context"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GeoSnap to access your photos for specimen selection"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
